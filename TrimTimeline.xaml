<UserControl x:Class="AeroCut.TrimTimeline"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="46">
    <Canvas x:Name="Board" Background="Transparent" ClipToBounds="False"
            SizeChanged="OnSizeChanged" MouseLeftButtonDown="OnTrackClick">
        <Border x:Name="Track" Height="6" CornerRadius="3"
                Background="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Border x:Name="Selection" Height="6" CornerRadius="3" Opacity="0.6"
                Background="{DynamicResource AccentFillColorDefaultBrush}" />
        <Thumb x:Name="PlayThumb" Width="16" Cursor="SizeWE">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Grid Background="Transparent">
                        <Rectangle Width="2" HorizontalAlignment="Center"
                                   Fill="{DynamicResource TextFillColorPrimaryBrush}" />
                        <Border Width="13" Height="13" CornerRadius="7" VerticalAlignment="Top"
                                Background="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Grid>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
        <Thumb x:Name="StartThumb" Width="12" Cursor="SizeWE">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border CornerRadius="4" Background="{DynamicResource AccentFillColorDefaultBrush}"
                            BorderThickness="1" BorderBrush="{DynamicResource TextFillColorPrimaryBrush}" />
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
        <Thumb x:Name="EndThumb" Width="12" Cursor="SizeWE">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border CornerRadius="4" Background="{DynamicResource AccentFillColorDefaultBrush}"
                            BorderThickness="1" BorderBrush="{DynamicResource TextFillColorPrimaryBrush}" />
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
    </Canvas>
</UserControl>

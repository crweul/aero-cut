<UserControl x:Class="AeroCut.AudioTrack"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="120">
    <UserControl.Resources>
        <Style x:Key="KfThumb" TargetType="Thumb">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Cursor" Value="SizeAll" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="7"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                BorderThickness="2"
                                BorderBrush="{DynamicResource TextFillColorPrimaryBrush}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="KfThumbSelected" TargetType="Thumb" BasedOn="{StaticResource KfThumb}">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="9"
                                Background="{DynamicResource TextFillColorPrimaryBrush}"
                                BorderThickness="3"
                                BorderBrush="{DynamicResource AccentFillColorDefaultBrush}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid x:Name="Board" ClipToBounds="True" Background="{DynamicResource ControlFillColorDefaultBrush}"
          SizeChanged="OnSizeChanged" MouseLeftButtonDown="OnBoardDown">
        <Image x:Name="Wave" Stretch="Fill" Opacity="0.4" />
        <Canvas x:Name="Layer">
            <Polyline x:Name="StepLine" StrokeThickness="2"
                      Stroke="{DynamicResource AccentFillColorDefaultBrush}" />
            <Thumb x:Name="GlobalBar" Height="20" Cursor="SizeNS">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Thumb x:Name="PlayThumb" Width="16" Cursor="SizeWE">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <Rectangle Width="2" HorizontalAlignment="Center"
                                       Fill="{DynamicResource TextFillColorPrimaryBrush}" />
                            <Border Width="13" Height="13" CornerRadius="7" VerticalAlignment="Top"
                                    Background="{DynamicResource TextFillColorPrimaryBrush}" />
                        </Grid>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Canvas>
    </Grid>
</UserControl>
